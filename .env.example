# Legal AI Assistant - 环境变量配置示例
# 重要：不要提交真实的API密钥到版本控制系统！
# 复制此文件为 .env 并填写你的配置

# 数据库配置
DATABASE_URL=sqlite:///db/app.db

# 安全配置（生产环境必须修改！）
SECRET_KEY=your-secure-secret-key-here-change-this

# LiteLLM代理配置（可选）
LLM_PROXY_BASE=http://localhost:4000/v1
LLM_MASTER_KEY=your-liteLLM-master-key-here

# OpenAI兼容API配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# 其他模型提供商（根据需要配置）
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
COHERE_API_KEY=your-cohere-api-key-here

# 默认模型配置
DEFAULT_MODEL_NAME=gpt-4o
ASYNC_MODEL_EXECUTION=false

# 本地模型配置（如使用Ollama）
OLLAMA_API_BASE=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama2:latest